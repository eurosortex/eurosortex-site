---
import '../styles/global.css';
import type { Locale } from '../config/locales';
import { localeConfig, locales } from '../config/locales';
import type { SiteContent } from '../i18n/content';
import SiteHeader from '../components/layout/SiteHeader.astro';
import SiteFooter from '../components/layout/SiteFooter.astro';
import MobileContactBar from '../components/layout/MobileContactBar.astro';
import { contact } from '../config/contact';
import { products } from '../data/products';

interface Props { locale: Locale; content: SiteContent }
const { locale, content: t } = Astro.props;
const canonical = new URL(localeConfig[locale].path, Astro.site);
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'EuroSortex Group',
  url: 'https://eurosortex.com',
  logo: 'https://eurosortex.com/images/eurosortex-logo.png',
  email: contact.email,
  telephone: contact.phoneE164,
  contactPoint: { '@type': 'ContactPoint', telephone: contact.phoneE164, contactType: 'sales', areaServed: 'PL', availableLanguage: ['pl', 'ru', 'uk', 'en'] },
};
const catalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: t.catalog.title,
  numberOfItems: products.length,
  itemListElement: products.map((product, index) => ({
    '@type': 'ListItem', position: index + 1,
    item: { '@type': 'Product', name: product.name, description: product.description[locale], category: product.category, offers: { '@type': 'Offer', priceCurrency: 'PLN', price: product.netPricePlnPerKg, url: `${canonical.href}#${product.id}`, businessFunction: 'https://purl.org/goodrelations/v1#Sell' } },
  })),
};
---
<!doctype html>
<html lang={localeConfig[locale].htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1e4d33" />
    <meta name="description" content={t.meta.description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {locales.map((item) => <link rel="alternate" hreflang={localeConfig[item].htmlLang} href={new URL(localeConfig[item].path, Astro.site)} />)}
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)} />
    <meta property="og:type" content="website" /><meta property="og:site_name" content="EuroSortex Group" /><meta property="og:title" content={t.meta.title} /><meta property="og:description" content={t.meta.description} /><meta property="og:url" content={canonical} /><meta property="og:locale" content={localeConfig[locale].htmlLang} />
    <meta name="twitter:card" content="summary" />
    <title>{t.meta.title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(catalogSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <SiteHeader locale={locale} content={t} />
    <main id="main"><slot /></main>
    <SiteFooter locale={locale} content={t} />
    <MobileContactBar content={t} locale={locale} />
    <script>
      const closeDetails = (selector: string) => document.querySelectorAll(selector).forEach((el) => el.removeAttribute('open'));
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        document.querySelectorAll('details[data-language-switcher][open]').forEach((detail) => { if (!detail.contains(target)) detail.removeAttribute('open'); });
        document.querySelectorAll('details[data-mobile-menu][open]').forEach((detail) => { if (!detail.contains(target)) detail.removeAttribute('open'); });
        if (target.closest('details[data-mobile-menu] a')) closeDetails('details[data-mobile-menu]');
      });
      document.addEventListener('keydown', (event) => { if (event.key === 'Escape') closeDetails('details[open]'); });
    </script>
  </body>
</html>
