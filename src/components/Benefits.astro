---
import type { Locale } from '../config/locales';
import { content } from '../i18n/content';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = content[locale];
const icons = ['box', 'photo', 'list', 'truck'];
const benefits = t.benefits.items.map((item, index) => ({ ...item, icon: icons[index] }));
---

<section class="benefits" aria-labelledby="benefits-label">
  <div class="container">
    <span class="kicker" id="benefits-label">{t.benefits.eyebrow}</span>
    <ul class="benefits-grid">
      {benefits.map((b) => (
        <li class="benefit">
          {b.icon === 'box' && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="4" y="7" width="16" height="13" rx="2" stroke="currentColor" stroke-width="1.8"></rect>
              <path d="M8 7V5.5A1.5 1.5 0 0 1 9.5 4h5A1.5 1.5 0 0 1 16 5.5V7" stroke="currentColor" stroke-width="1.8"></path>
            </svg>
          )}
          {b.icon === 'photo' && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="3.5" y="5" width="17" height="14" rx="2" stroke="currentColor" stroke-width="1.8"></rect>
              <circle cx="9" cy="10" r="1.7" stroke="currentColor" stroke-width="1.6"></circle>
              <path d="M4 17l5-4 4 3 3-2 4 3" stroke="currentColor" stroke-width="1.8"></path>
            </svg>
          )}
          {b.icon === 'list' && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 6h14M5 12h10M5 18h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
              <circle cx="19" cy="12" r="2" stroke="currentColor" stroke-width="1.6"></circle>
            </svg>
          )}
          {b.icon === 'truck' && (
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 16V7h11v9" stroke="currentColor" stroke-width="1.8"></path>
              <path d="M14 10h4l3 3v3h-2" stroke="currentColor" stroke-width="1.8"></path>
              <circle cx="7" cy="17.5" r="1.8" stroke="currentColor" stroke-width="1.6"></circle>
              <circle cx="17" cy="17.5" r="1.8" stroke="currentColor" stroke-width="1.6"></circle>
            </svg>
          )}
          <span class="benefit-title">{b.title}</span>
          <span class="benefit-desc">{b.text}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .benefits {
    padding-block: 32px;
  }

  .benefits-grid {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .benefit {
    background: var(--surface);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    color: var(--green);
  }

  .benefit svg {
    flex: none;
  }

  .benefit-title {
    font-size: 15px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-strong);
  }

  .benefit-desc {
    font-size: 14px;
    line-height: 1.45;
    color: var(--text-muted);
  }

  @media (min-width: 768px) {
    .benefits {
      padding-block: 40px;
    }

    .benefit {
      padding: 20px 22px;
    }

    .benefit-title {
      font-size: 16px;
    }

    .benefit-desc {
      line-height: 1.5;
    }
  }

  @media (min-width: 1024px) {
    .benefits {
      padding-block: 44px 52px;
    }

    .benefits-grid {
      grid-template-columns: repeat(4, 1fr);
      margin-top: 18px;
    }

    .benefit {
      padding: 22px 24px;
      gap: 10px;
    }
  }
</style>
