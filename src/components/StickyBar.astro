---
import IconWhatsApp from './IconWhatsApp.astro';
import IconPhone from './IconPhone.astro';
import type { Locale } from '../config/locales';
import { contact, whatsappUrl } from '../config/contact';
import { content } from '../i18n/content';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = content[locale];
---

<div class="sticky-bar">
  <a
    class="btn btn-primary bar-wa"
    href={whatsappUrl('general', locale)}
    data-analytics-whatsapp
    data-analytics-placement="mobile_sticky"
  >
    <IconWhatsApp size={18} />
    WhatsApp
  </a>
  <a class="btn btn-secondary bar-call" href={`tel:${contact.phoneE164}`} data-analytics-placement="mobile_sticky">
    <IconPhone size={16} />
    {t.common.call}
  </a>
</div>

<style>
  /* Pinned to the viewport bottom while scrolling; being the last element in
     flow, it settles after the footer and never covers it. */
  .sticky-bar {
    position: sticky;
    bottom: 0;
    z-index: 46;
    background: var(--surface);
    border-top: 1px solid var(--border-strong);
    padding: 8px 16px calc(8px + env(safe-area-inset-bottom));
    min-height: 64px;
    display: flex;
    gap: 10px;
    box-shadow: 0 -6px 16px rgba(43, 43, 40, 0.08);
  }

  .bar-wa {
    flex: 1.5;
    height: 48px;
    font-size: 16px;
    font-weight: 800;
    gap: 8px;
  }

  .bar-call {
    flex: 1;
    height: 48px;
    font-size: 16px;
    gap: 8px;
  }

  @media (min-width: 768px) {
    .sticky-bar {
      padding-inline: 32px;
    }
  }

  @media (min-width: 1024px) {
    .sticky-bar {
      display: none;
    }
  }
</style>
