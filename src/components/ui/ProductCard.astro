---
import type { Locale } from '../../config/locales';
import { formatPrice, type Product } from '../../data/products';
import type { SiteContent } from '../../i18n/content';
import { productWhatsappUrl } from '../../config/contact';
import Icon from './Icon.astro';
import PlaceholderMedia from './PlaceholderMedia.astro';
interface Props { product: Product; locale: Locale; content: SiteContent }
const { product, locale, content: t } = Astro.props;
---
<article class="product-card" id={product.id} data-product data-category={product.category}>
  <PlaceholderMedia label={product.name} ratio="card" />
  <div class="product-card__body">
    <div class="product-card__heading"><h3>{product.name}</h3><span>{t.common.grade} {product.grade}</span></div>
    <p>{product.description[locale]}</p>
    <dl class="product-specs">
      {product.composition && <><dt>{t.common.approxComposition}</dt><dd>{product.composition[locale]}</dd></>}
      <dt>{t.common.branded}</dt><dd>{product.brandedShareApprox[locale]}</dd>
      {product.disposalShareMax && <><dt>{t.common.disposal}</dt><dd>{product.disposalShareMax[locale]}</dd></>}
      <dt>{t.common.minimumOrder}</dt><dd>20 kg</dd>
    </dl>
    <div class="product-price"><strong>{formatPrice(product.netPricePlnPerKg, locale)} {t.common.netSuffix}</strong><small>{t.common.vat}</small></div>
    <a class="button button--soft button--full" href={productWhatsappUrl(product.name, locale)} target="_blank" rel="noopener"><Icon name="whatsapp" size={16} />{t.common.productQuestion}</a>
  </div>
</article>
