---
import { localeConfig, locales, type Locale } from '../../config/locales';
import Icon from './Icon.astro';

interface Props { locale: Locale; label: string; compact?: boolean }
const { locale, label, compact = false } = Astro.props;
---

<details class:list={['language-switcher', { compact }]} data-language-switcher>
  <summary aria-label={label} title={label}>
    <span>{localeConfig[locale].code}</span>
    <Icon name="chevron" size={16} />
  </summary>
  <div class="language-menu">
    {locales.map((item) => (
      <a href={localeConfig[item].path} lang={localeConfig[item].htmlLang} aria-current={item === locale ? 'page' : undefined}>
        <span>{localeConfig[item].label}</span><small>{localeConfig[item].code}</small>
      </a>
    ))}
  </div>
</details>
