---
import IconWhatsApp from './IconWhatsApp.astro';
import type { Locale } from '../config/locales';
import { localeConfig, locales } from '../config/locales';
import { contact, whatsappUrl } from '../config/contact';
import { content } from '../i18n/content';
import { ui } from '../i18n/ui';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = content[locale];
const u = ui[locale];
const nav = [
  { href: '#oferta', label: t.nav.offer },
  { href: '#jakosc', label: t.nav.quality },
  { href: '#jak-zamowic', label: t.nav.process },
  { href: '#dostawa', label: t.nav.terms },
  { href: '#faq', label: t.nav.faq },
];
const phoneHref = `tel:${contact.phoneE164}`;
const waGeneral = whatsappUrl('general', locale);
---

<header class="site-header">
  <div class="header-inner container">
    <a href={localeConfig[locale].path} class="logo-link" aria-label={`EuroSortex Group — ${u.home}`}>
      <img src="/images/logo.png" alt="EuroSortex Group" class="logo" width="196" height="44" />
    </a>

    <nav class="header-nav" aria-label={u.mainNav}>
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <div class="header-actions">
      <div class="lang" data-lang-ui>
        <button
          type="button"
          class="lang-trigger"
          aria-label={t.languageLabel}
          aria-haspopup="true"
          aria-expanded="false"
        >
          {localeConfig[locale].code}
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
        <div class="lang-menu" hidden>
          {locales.map((item) => (
            <a href={localeConfig[item].path} lang={item} aria-current={item === locale ? 'page' : undefined}>
              {localeConfig[item].label}
              {item === locale && <span aria-hidden="true" class="lang-check">✓</span>}
            </a>
          ))}
        </div>
      </div>

      <a class="header-phone" href={phoneHref}>tel. {contact.phoneDisplay}</a>

      <a class="header-cta btn btn-primary" href={waGeneral}>
        <IconWhatsApp size={16} />
        {t.common.availability}
      </a>

      <button
        type="button"
        class="menu-trigger"
        aria-label={u.menu}
        aria-expanded="false"
        aria-controls="menu-panel"
      >
        <svg class="icon-burger" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
        <svg class="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </div>

  <div class="menu-backdrop" hidden></div>
  <div class="menu-panel" id="menu-panel" hidden>
    <nav aria-label={u.menu}>
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="menu-contact">
      <a href={phoneHref} class="menu-phone">tel. {contact.phoneDisplay}</a>
      <a class="btn btn-primary menu-cta" href={waGeneral}>
        <IconWhatsApp size={17} />
        {t.common.availability}
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    height: 60px;
  }

  .logo-link {
    display: block;
    flex: none;
  }

  .logo {
    height: 34px;
    width: auto;
    display: block;
  }

  .header-nav {
    display: none;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* language selector */
  .lang {
    position: relative;
  }

  .lang-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    min-height: 44px;
    min-width: 52px;
    padding: 0 9px;
    border: 1.5px solid var(--border-input);
    border-radius: 8px;
    background: #fff;
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
  }

  .lang-trigger:hover {
    border-color: var(--green);
    color: var(--green);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    width: 200px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 12px 24px rgba(43, 43, 40, 0.16);
    z-index: 70;
    overflow: hidden;
  }

  .lang-menu a {
    display: flex;
    align-items: center;
    min-height: 48px;
    padding: 0 14px;
    font-size: 15px;
    font-weight: 600;
    color: var(--text-mid);
    border-bottom: 1px solid var(--border-soft);
  }

  .lang-menu a:last-child {
    border-bottom: 0;
  }

  .lang-menu a:hover {
    background: var(--surface-cream);
    color: var(--green);
  }

  .lang-menu a[aria-current='page'] {
    justify-content: space-between;
    font-weight: 800;
    color: var(--green);
    background: var(--green-soft);
  }

  .lang-menu a[aria-current='page']:hover {
    background: var(--green-soft-hover);
    color: var(--green-deep);
  }

  .lang-check {
    font-weight: 800;
  }

  .header-phone {
    display: none;
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
  }

  .header-phone:hover {
    color: var(--green);
  }

  .header-cta {
    display: none;
    min-height: 44px;
    padding: 0 18px;
    font-size: 15px;
    border-radius: 8px;
  }

  .menu-trigger {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    color: var(--text-strong);
  }

  .menu-trigger:hover {
    background: var(--surface-cream);
  }

  .menu-trigger .icon-close {
    display: none;
  }

  .menu-trigger[aria-expanded='true'] {
    background: var(--surface-cream);
  }

  .menu-trigger[aria-expanded='true'] .icon-burger {
    display: none;
  }

  .menu-trigger[aria-expanded='true'] .icon-close {
    display: block;
  }

  /* dropdown menu (mobile + tablet) */
  .menu-backdrop {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 100vh;
    background: rgba(43, 43, 40, 0.35);
    z-index: 43;
  }

  .menu-panel {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--surface);
    border-bottom: 1px solid var(--border-strong);
    box-shadow: 0 12px 24px rgba(43, 43, 40, 0.12);
    z-index: 44;
  }

  .menu-panel nav {
    display: flex;
    flex-direction: column;
    padding: 8px 16px;
  }

  .menu-panel nav a {
    display: flex;
    align-items: center;
    min-height: 48px;
    font-size: 17px;
    font-weight: 700;
    color: var(--text-strong);
    border-bottom: 1px solid var(--border-soft);
  }

  .menu-panel nav a:last-child {
    border-bottom: 0;
  }

  .menu-panel nav a:hover {
    color: var(--green);
  }

  .menu-contact {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 8px 16px 16px;
    border-top: 1px solid var(--border);
  }

  .menu-phone {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-soft);
    padding: 6px 0;
  }

  .menu-cta {
    height: 50px;
    font-size: 16px;
  }

  /* ---- tablet: 768–1023 ---- */
  @media (min-width: 768px) {
    .header-inner {
      height: 64px;
      gap: 14px;
    }

    .logo {
      height: 38px;
    }

    .header-actions {
      gap: 14px;
    }

    .lang-trigger {
      min-width: 56px;
      padding: 0 10px;
    }

    .lang-menu a {
      min-height: 44px;
    }

    .header-cta {
      display: inline-flex;
    }

    .menu-panel nav {
      padding: 8px 32px 16px;
    }

    .menu-backdrop {
      display: none;
    }

    .menu-contact {
      display: none;
    }
  }

  @media (min-width: 900px) {
    .header-phone {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }
  }

  /* ---- desktop: 1024+ ---- */
  @media (min-width: 1024px) {
    .header-inner {
      height: auto;
      padding-block: 12px;
      justify-content: flex-start;
      gap: 28px;
    }

    .logo {
      height: 44px;
    }

    .header-nav {
      display: flex;
      gap: 24px;
      font-size: 15px;
      font-weight: 600;
      margin-left: 4px;
    }

    .header-nav a {
      color: var(--text-mid);
    }

    .header-nav a:hover {
      color: var(--green);
    }

    .header-actions {
      margin-left: auto;
      gap: 16px;
    }

    .header-cta {
      padding: 11px 20px;
      min-height: 0;
    }

    .menu-trigger,
    .menu-panel,
    .menu-backdrop {
      display: none;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .lang-menu {
      animation: drop-in 0.15s ease;
    }

    .menu-panel {
      animation: drop-in 0.18s ease;
    }

    .menu-backdrop {
      animation: fade-in 0.18s ease;
    }

    @keyframes drop-in {
      from {
        opacity: 0;
        transform: translateY(-6px);
      }
    }

    @keyframes fade-in {
      from {
        opacity: 0;
      }
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('.site-header')!;
  const langTrigger = header.querySelector<HTMLButtonElement>('.lang-trigger')!;
  const langMenu = header.querySelector<HTMLElement>('.lang-menu')!;
  const menuTrigger = header.querySelector<HTMLButtonElement>('.menu-trigger')!;
  const menuPanel = header.querySelector<HTMLElement>('.menu-panel')!;
  const menuBackdrop = header.querySelector<HTMLElement>('.menu-backdrop')!;

  function setLang(open: boolean) {
    langMenu.hidden = !open;
    langTrigger.setAttribute('aria-expanded', String(open));
    if (open) setMenu(false);
  }

  function setMenu(open: boolean) {
    menuPanel.hidden = !open;
    menuBackdrop.hidden = !open;
    menuTrigger.setAttribute('aria-expanded', String(open));
    if (open) setLang(false);
  }

  const langOpen = () => !langMenu.hidden;
  const menuOpen = () => !menuPanel.hidden;

  langTrigger.addEventListener('click', () => setLang(!langOpen()));
  menuTrigger.addEventListener('click', () => setMenu(!menuOpen()));
  menuBackdrop.addEventListener('click', () => setMenu(false));

  // a tap on a section link should close the menu before scrolling
  menuPanel.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => setMenu(false));
  });

  document.addEventListener('click', (e) => {
    if (langOpen() && !(e.target as Element).closest('[data-lang-ui]')) setLang(false);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    if (langOpen()) {
      setLang(false);
      langTrigger.focus();
    }
    if (menuOpen()) {
      setMenu(false);
      menuTrigger.focus();
    }
  });
</script>
