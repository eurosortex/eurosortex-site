---
import type { SiteContent } from '../../i18n/content';
import type { Locale } from '../../config/locales';
import { contact, whatsappUrl } from '../../config/contact';
import Icon from '../ui/Icon.astro';
interface Props { content: SiteContent; locale: Locale }
const { content: t, locale } = Astro.props;
---
<aside class="mobile-contact-bar" aria-label={t.footer.contact}>
  <a class="button button--primary" href={whatsappUrl('general', locale)} target="_blank" rel="noopener"><Icon name="whatsapp" size={18} />{t.common.whatsapp}</a>
  <a class="button button--secondary" href={`tel:${contact.phoneE164}`}><Icon name="phone" size={18} />{t.common.call}</a>
</aside>
