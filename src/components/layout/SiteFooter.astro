---
import type { Locale } from '../../config/locales';
import type { SiteContent } from '../../i18n/content';
import { contact } from '../../config/contact';
import LanguageSwitcher from '../ui/LanguageSwitcher.astro';
interface Props { locale: Locale; content: SiteContent }
const { locale, content: t } = Astro.props;
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div><img class="footer-logo" src="/images/eurosortex-logo.png" width="245" height="62" alt="EuroSortex Group" /><p>{t.footer.description}</p><p>{t.footer.dispatch}</p></div>
    <div><strong>{t.footer.navigation}</strong><a href="#oferta">{t.nav.offer}</a><a href="#jakosc">{t.nav.quality}</a><a href="#zamowienie">{t.nav.process}</a><a href="#dostawa">{t.nav.terms}</a><a href="#faq">{t.nav.faq}</a></div>
    <div><strong>{t.footer.contact}</strong><a href={`tel:${contact.phoneE164}`}>{contact.phoneDisplay}</a><a href={`mailto:${contact.email}`}>{contact.email}</a><span>{contact.workingHours}</span><LanguageSwitcher locale={locale} label={t.languageLabel} /></div>
  </div>
  <div class="shell footer-bottom"><span>© {new Date().getFullYear()} EuroSortex Group</span><span>{t.footer.legalPlaceholder}</span><span>{t.footer.privacyPlaceholder}</span></div>
</footer>
