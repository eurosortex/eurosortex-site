---
import IconWhatsApp from './IconWhatsApp.astro';
import type { Locale } from '../config/locales';
import { whatsappUrl } from '../config/contact';
import { content } from '../i18n/content';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = content[locale];
---

<section class="photo-cta">
  <div class="container">
    <div class="strip">
      <div class="strip-text">
        <h3>{t.photoCta.title}</h3>
        <p>{t.photoCta.text}</p>
      </div>
      <a class="btn btn-primary strip-btn" href={whatsappUrl('photos', locale)}>
        <IconWhatsApp size={18} />
        {t.photoCta.action}
      </a>
    </div>
  </div>
</section>

<style>
  .photo-cta {
    padding-top: 24px;
  }

  .strip {
    background: var(--surface-cream);
    border: 1px solid var(--border-cream);
    border-radius: 12px;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .strip-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  h3 {
    margin: 0;
    font-size: 20px;
    line-height: 1.25;
    font-weight: 800;
    color: var(--text-strong);
  }

  p {
    margin: 0;
    font-size: 15px;
    line-height: 1.5;
    color: var(--text-soft);
  }

  .strip-btn {
    height: 50px;
    font-size: 15.5px;
    white-space: normal;
    text-align: center;
  }

  @media (min-width: 768px) {
    .strip {
      padding: 22px 28px;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 20px;
    }

    .strip-text {
      flex: 1;
      min-width: 300px;
      gap: 5px;
    }

    .strip-btn {
      height: auto;
      min-height: 50px;
      padding: 0 22px;
      white-space: nowrap;
    }
  }

  @media (min-width: 1024px) {
    .photo-cta {
      padding-top: 40px;
    }

    .strip {
      padding: 30px 36px;
      gap: 32px;
      flex-wrap: nowrap;
    }

    h3 {
      font-size: 23px;
    }

    p {
      font-size: 15.5px;
    }

    .strip-btn {
      font-size: 16px;
      padding: 14px 24px;
    }
  }
</style>
