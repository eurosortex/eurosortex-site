---
import IconWhatsApp from './IconWhatsApp.astro';
import type { Locale } from '../config/locales';
import { contact, whatsappUrl } from '../config/contact';
import { content } from '../i18n/content';
import { ui } from '../i18n/ui';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = content[locale];
const u = ui[locale];
const phoneHref = `tel:${contact.phoneE164}`;
---

<section class="final-cta" id="kontakt">
  <div class="container final-grid">
    <div class="final-content">
      <span class="kicker final-kicker">{t.finalCta.eyebrow}</span>
      <h2>{t.finalCta.title}</h2>
      <p class="final-lead">{t.finalCta.text}</p>
      <div class="final-ctas">
        <a
          class="btn btn-inverse final-btn-wa"
          href={whatsappUrl('general', locale)}
          data-analytics-whatsapp
          data-analytics-placement="final_cta"
        >
          <IconWhatsApp size={19} />
          {t.common.availability} — WhatsApp
        </a>
        <a class="btn btn-outline-light final-btn-call" href={phoneHref} data-analytics-placement="final_cta">{u.bookCall}</a>
      </div>
      <p class="final-micro">{t.hero.note}</p>
    </div>

    <dl class="summary">
      {t.finalCta.summary.map((row) => (
        <div class="summary-row">
          <dt class="mono-label">{row.label}</dt>
          <dd>{row.value}</dd>
        </div>
      ))}
      <div class="summary-row is-contact">
        <dt class="mono-label">{u.phone}</dt>
        <dd><a href={phoneHref} data-analytics-placement="final_cta">{contact.phoneDisplay}</a></dd>
      </div>
      <div class="summary-row is-contact">
        <dt class="mono-label">E-mail</dt>
        <dd><a href={`mailto:${contact.email}`}>{contact.email}</a></dd>
      </div>
    </dl>
  </div>
</section>

<style>
  .final-cta {
    background: var(--green);
  }

  .final-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-block: 36px;
  }

  .final-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .final-kicker {
    color: var(--green-pale);
  }

  h2 {
    margin: 0;
    font-size: 28px;
    line-height: 1.15;
    font-weight: 800;
    color: #fff;
    text-wrap: pretty;
  }

  .final-lead {
    margin: 0;
    font-size: 16px;
    line-height: 1.55;
    color: var(--green-pale-text);
  }

  .final-ctas {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .final-btn-wa {
    height: 52px;
    font-size: 16.5px;
    gap: 10px;
  }

  .final-btn-call {
    height: 50px;
    font-size: 16.5px;
  }

  .final-micro {
    display: none;
    margin: 0;
    font-size: 14px;
    color: var(--green-pale);
  }

  .summary {
    margin: 4px 0 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--green-row-border);
    border: 1px solid var(--green-row-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .summary-row {
    background: var(--green-row);
    padding: 12px 16px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: 14px;
  }

  .summary-row .mono-label {
    color: var(--green-pale);
    padding-top: 2px;
  }

  .summary-row dd {
    margin: 0;
    font-weight: 700;
    color: #fff;
    text-align: right;
  }

  .summary-row dd a {
    color: #fff;
  }

  .summary-row dd a:hover {
    color: var(--green-pale-text);
  }

  .summary-row.is-contact {
    display: none;
  }

  @media (min-width: 768px) {
    .final-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 32px;
      align-items: center;
      padding-block: 48px;
    }

    .final-content {
      gap: 14px;
    }

    .final-ctas {
      flex-direction: row;
      flex-wrap: wrap;
      margin-top: 4px;
    }

    .final-btn-wa {
      height: auto;
      min-height: 50px;
      padding: 0 20px;
      font-size: 16px;
    }

    .final-btn-call {
      height: auto;
      min-height: 48px;
      padding: 0 20px;
      font-size: 16px;
    }

    .summary {
      margin: 0;
    }

    .summary-row.is-contact {
      display: flex;
    }
  }

  @media (min-width: 1024px) {
    .final-grid {
      column-gap: 56px;
      padding-block: 64px;
    }

    .final-content {
      gap: 18px;
    }

    h2 {
      font-size: 36px;
    }

    .final-lead {
      font-size: 17px;
      line-height: 1.6;
      max-width: 56ch;
    }

    .final-ctas {
      gap: 14px;
      margin-top: 6px;
    }

    .final-btn-wa {
      min-height: 0;
      padding: 15px 26px;
      font-size: 17px;
    }

    .final-btn-call {
      min-height: 0;
      padding: 14px 24px;
      font-size: 17px;
    }

    .final-micro {
      display: block;
    }

    .summary {
      border-radius: 12px;
    }

    .summary-row {
      padding: 16px 20px;
      gap: 16px;
      font-size: 15px;
    }

    .summary-row .mono-label {
      font-size: 11px;
    }
  }
</style>
